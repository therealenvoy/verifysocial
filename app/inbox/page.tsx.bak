   455|              </section>
   456|            </div>
   457|          </div>
   458|        </div>
   459|
   460|        {/* Mobile layout */}
   461|        <div className="flex-1 lg:hidden flex flex-col overflow-hidden">
   462|          <div className="border-b border-border">
   463|            <div className="flex">
   464|              {(['chats', 'thread', 'fan', 'ppv'] as MobileTab[]).map(tab => (
   465|                <button
   466|                  key={tab}
   467|                  className={cn('flex-1 py-3 text-sm font-medium border-b-2', mobileTab === tab ? 'border-primary text-primary' : 'border-transparent text-muted-text')}
   468|                  onClick={() => setMobileTab(tab)}
   469|                >
   470|                  {tab === 'chats' && 'Chats'}
   471|                  {tab === 'thread' && 'Thread'}
   472|                  {tab === 'fan' && 'Fan'}
   473|                  {tab === 'ppv' && 'PPV'}
   474|                </button>
   475|              ))}
   476|            </div>
   477|          </div>
   478|
   479|          <div className="flex-1 overflow-y-auto p-4">
   480|            {mobileTab === 'chats' && (
   481|              <div className="space-y-4">
   482|                {conversations.map(conv => (
   483|                  <div
   484|                    key={conv.id}
   485|                    className="rounded-lg border border-border p-4"
   486|                    onClick={() => {
   487|                      setSelectedConversationId(conv.id);
   488|                      setMobileTab('thread');
   489|                    }}
   490|                  >
   491|                    <div className="flex items-center gap-3">
   492|                      <div className={cn('h-10 w-10 rounded-lg flex items-center justify-center', conv.avatarColor)}>
   493|                        {conv.fanName.charAt(0)}
   494|                      </div>
   495|                      <div className="flex-1">
   496|                        <div className="flex items-center justify-between">
   497|                          <h3 className="font-medium">{conv.fanName}</h3>
   498|                          <span className="text-xs text-muted-text">{conv.timestamp}</span>
   499|                        </div>
   500|                        <p className="mt-1 text-sm text-muted-text truncate">{conv.lastMessage}</p>
