>
{darkMode ? <Sun className="h-4 w-4" /> : <Moon className="h-4 w-4" />}
</button>
Sandbox Mode
</button>
<button className="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-surface hover:bg-primary/90">
New Message
</button>
