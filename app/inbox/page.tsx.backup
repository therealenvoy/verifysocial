<Target className="h-4 w-4" />
Lifecycle
</h3>
<div className="rounded-lg border border-border p-4">
<div className="flex items-center justify-between">
<span className="font-medium">{fanDetails.lifecycleStage}</span>
<span className="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">High‑Intent</span>
</div>
<div className="mt-4 h-2 rounded-full bg-border overflow-hidden">
<div className="h-full w-3/4 bg-primary"></div>
