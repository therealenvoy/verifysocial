</div>
<p className="mt-1 truncate text-sm text-muted-text">{conv.lastMessage}</p>
<div className="mt-2 flex flex-wrap gap-1">
{conv.unread && (
<span className="rounded-full bg-primary px-2 py-0.5 text-xs font-medium text-surface">New</span>
)}
<span className="rounded-full bg-success/10 px-2 py-0.5 text-xs font-medium text-success">
${conv.spend}
</span>
<span className="rounded-full border border-border px-2 py-0.5 text-xs font-medium">
{conv.lifecycle}
</span>
{conv.safety === 'review' && (
<span className="rounded-full bg-warning/10 px-2 py-0.5 text-xs font-medium text-warning">
Review
</span>
)}
</div>
</div>
</div>
))}
</div>
</div>
{/* Center: Chat thread */}
<div className="flex-1 border-r border-border bg-surface overflow-hidden flex flex-col">
{/* Chat header */}
<div className="border-b border-border p-4">
