Unread
</button>
<button className="rounded-lg border border-border px-3 py-1.5 text-xs font-medium hover:bg-elevated-surface">
VIP
</button>
<button className="ml-auto text-muted-text hover:text-foreground">
<Filter className="h-4 w-4" />
</button>
</div>
</div>
<div className="p-2">
{conversations.map(conv => (
<div
key={conv.id}
className={cn(
'flex cursor-pointer items-start gap-3 rounded-lg p-3 hover:bg-elevated-surface',
selectedConversationId === conv.id && 'bg-elevated-surface border border-border'
)}
onClick={() => setSelectedConversationId(conv.id)}
>
<div className={cn('flex h-10 w-10 items-center justify-center rounded-lg', conv.avatarColor)}>
{conv.fanName.charAt(0)}
</div>
<div className="flex-1 min-w-0">
